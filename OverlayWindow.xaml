<Window x:Class="ScreenTranslator2.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Translation Overlay"
        Height="Auto" Width="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Focusable="False"
        IsHitTestVisible="False"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Loaded="Window_Loaded">

    <Border Background="#E61E1E1E"
            CornerRadius="12"
            Padding="20"
            Margin="20"
            BorderBrush="#44FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="TRANSLATION" Foreground="#88FFFFFF" FontSize="12" FontWeight="Bold" Margin="0,0,0,8" />
            <TextBlock x:Name="TranslationText"
                       Foreground="White"
                       FontSize="16"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI" />
        </StackPanel>
    </Border>
</Window>

